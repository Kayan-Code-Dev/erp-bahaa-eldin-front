# Backend API URL (required)
VITE_BACKEND_URL=https://api.dressnmore.it.com

# WebSocket / Reverb (Laravel Echo) - for real-time notifications
# Do NOT put real secrets here; VITE_* vars are embedded in the frontend bundle.
VITE_REVERB_APP_KEY=your_reverb_app_key
VITE_REVERB_HOST=api.dressnmore.it.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_AUTH_ENDPOINT=https://api.dressnmore.it.com/broadcasting/custom-auth

# Optional: disable WebSocket
# VITE_ENABLE_WEBSOCKET=false
